{
  "name": "paytm-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "postinstall": "cd packages/db && npx prisma generate",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@prisma/client": "^7.3.0",
    "@prisma/nextjs-monorepo-workaround-plugin": "^6.10.1",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "*",
    "@types/react": "^19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint-config-turbo": "*",
    "prettier": "^3.4.2",
    "prisma": "^7.3.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/extension-accelerate": "^1.3.0",
    "@turbo/gen": "^2.7.2",
    "@turbo/workspaces": "^2.7.2",
    "bcryptjs": "^2.4.3",
    "next-auth": "^4.24.13",
    "zod": "^3.23.8"
  },
  "overrides": {
    "eslint": "^9.21.0",
    "glob": "^13.0.0",
    "rimraf": "^6.0.1",
    "@humanwhocodes/config-array": "npm:@eslint/config-array@^0.19.2",
    "@humanwhocodes/object-schema": "npm:@eslint/object-schema@^2.1.6"
